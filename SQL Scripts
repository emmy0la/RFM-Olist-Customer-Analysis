-- Customer_rfm_base table
DROP TABLE IF EXISTS customer_rfm_base;
CREATE TABLE customer_rfm_base AS
WITH max_date AS (
    SELECT MAX(order_purchase_t) AS max_dt
    FROM customer_transactions
),
customer_metrics AS (
    SELECT 
        customer_unique_,
        MAX(order_purchase_t) AS last_purchase_date,
        COUNT(DISTINCT order_id) AS total_orders,
        SUM(payment_value) AS total_spent
    FROM customer_transactions
    GROUP BY customer_unique_
  ORDER BY total_orders DESC
)
SELECT 
    cm.customer_unique_,
    cm.last_purchase_date,
    julianday(md.max_dt) - julianday(cm.last_purchase_date) AS recency_days,
    cm.total_orders,
    cm.total_spent
FROM customer_metrics cm
CROSS JOIN max_date md;

SELECT 
    total_orders,
    COUNT(*) AS customer_count
FROM customer_rfm_base
GROUP BY total_orders
ORDER BY total_orders;

-- See output
SELECT COUNT(*) FROM customer_rfm_base;
SELECT * FROM customer_rfm_base;

-- Distribution inspection
SELECT 
    MIN(recency_days) AS min_recency,
    MAX(recency_days) AS max_recency,
    AVG(total_orders) AS avg_frequency,
    AVG(recency_days) AS avg_recency,
    AVG(total_spent) AS avg_monetary,
    MIN(total_spent) AS min_monetary,
    MAX(total_spent) AS max_monetary
FROM customer_rfm_base;

-- Distributions inspection
SELECT total_orders, COUNT(*) 
FROM customer_rfm_base
GROUP BY total_orders
ORDER BY total_orders;

