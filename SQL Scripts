-- Customer RFM scores table (1-5, where 5 is best)
DROP TABLE IF EXISTS customer_rfm_scores;
CREATE TABLE customer_rfm_scores AS
SELECT
    customer_unique_,
    recency_days,
    total_orders,
    total_spent,

    /* RECENCY SCORE
       Lower recency = better customer
    */
    CASE
        WHEN recency_days <= 30 THEN 5
        WHEN recency_days <= 90 THEN 4
        WHEN recency_days <= 180 THEN 3
        WHEN recency_days <= 365 THEN 2
        ELSE 1
    END AS r_score,

    /* FREQUENCY SCORE
       Most customers ordered once,
       so repeat purchases are highly valuable
    */
    CASE
        WHEN total_orders >= 5 THEN 5
        WHEN total_orders = 4 THEN 4
        WHEN total_orders = 3 THEN 3
        WHEN total_orders = 2 THEN 2
        ELSE 1
    END AS f_score,

    /* MONETARY SCORE
       Based on actual spending distribution
    */
    CASE
        WHEN total_spent >= 1000 THEN 5
        WHEN total_spent >= 500 THEN 4
        WHEN total_spent >= 250 THEN 3
        WHEN total_spent >= 100 THEN 2
        ELSE 1
    END AS m_score

FROM customer_rfm_base;

-- RFM scores preview
SELECT
    customer_unique_,
    recency_days,
    total_orders,
    total_spent,
    r_score,
    f_score,
    m_score,
    (r_score + f_score + m_score) AS rfm_total_score
FROM customer_rfm_scores
ORDER BY rfm_total_score DESC;

-- Customer segments table
DROP TABLE IF EXISTS customer_segments;
CREATE TABLE customer_segments AS
SELECT 
    customer_unique_,
    r_score,
    f_score,
    m_score,

    CASE
        /* Best customers:
           Recent, frequent, high spenders
        */
        WHEN r_score >= 4 
             AND f_score >= 4 
             AND m_score >= 4
        THEN 'Champions'

        /* Strong repeat buyers with value */
        WHEN f_score >= 4 
             AND m_score >= 3
        THEN 'Loyal Customers'

        /* Recent customers still early in journey */
        WHEN r_score >= 4 
             AND f_score = 1
        THEN 'New Customers'

        /* Good engagement and spending potential */
        WHEN r_score >= 3 
             AND f_score >= 2 
             AND m_score >= 2
        THEN 'Potential Loyalists'

        /* Previously valuable but inactive recently */
        WHEN r_score <= 2 
             AND (f_score >= 3 OR m_score >= 3)
        THEN 'At Risk'

        /* Weak engagement overall */
        WHEN r_score <= 2 
             AND f_score = 1 
             AND m_score <= 2
        THEN 'Lost Customers'

        /* Customers requiring monitoring */
        ELSE 'Need Attention'
    END AS segment_label
FROM customer_rfm_scores;

-- Segment distribution
SELECT segment_label, COUNT(*) AS customer_count
FROM customer_segments
GROUP BY segment_label
ORDER BY customer_count DESC;

